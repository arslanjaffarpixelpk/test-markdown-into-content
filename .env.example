# Copy to `.env.local` and fill in.
#
# AI mode: 'mock' (simulated streaming of local fixtures, no backend) or 'real'
# (Flask AI server over SSE). If unset, defaults to 'real' when a server URL is
# configured below, otherwise 'mock'. You can also flip modes at runtime from the
# header toggle (persisted in localStorage).
VITE_AI_MODE=

# Base URL for the AI backend. The chat client calls `${VITE_AI_SERVER_URL}/api/...`.
# Use `/ai` to route through the Vite dev proxy (see vite.config.ts) and avoid CORS,
# or an absolute URL like https://flask.pakistanlawbot.com to call it directly (the
# server must then allow CORS from http://localhost:5173).
VITE_AI_SERVER_URL=/ai

# Sent as the `X-API-Key` header. Leave blank if the server doesn't require one.
VITE_XAPIKey=

# LLM model id passed to the Flask server (defaults to "gemini").
VITE_AI_MODEL=gemini
