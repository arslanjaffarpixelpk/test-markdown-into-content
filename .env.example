# Copy to `.env.local` and fill in.
#
# Base URL for the AI backend. Use `/ai` to route through the Vite dev proxy
# (see vite.config.ts) to a local Flask server and avoid CORS. Alternatively set
# an absolute URL like http://localhost:5000 to call the server directly (then the
# server must send CORS headers for http://localhost:5173).
VITE_AI_SERVER_URL=/ai

# API key sent as the `X-API-Key` header. Leave blank if the server doesn't require one.
VITE_XAPIKey=
