{
  "name": "rich-content-markdown-renderer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Prototype: render structured AI markdown responses (charts, tables, timelines, flow diagrams, infographics, interactive templates) inside chat, via a modular renderer registry.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.15",
    "@radix-ui/react-progress": "^1.1.11",
    "@radix-ui/react-scroll-area": "^1.2.13",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.16",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "katex": "^0.16.11",
    "lucide-react": "^1.23.0",
    "mermaid": "^11.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "recharts": "^2.15.0",
    "rehype-highlight": "^7.0.1",
    "rehype-katex": "^7.0.1",
    "remark-directive": "^3.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
